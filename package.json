{
  "name": "lego-photo-mosaic",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicacao para transformar fotos em projetos de mosaico LEGO.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "tsc && npm --prefix frontend run build",
    "build:backend": "tsc",
    "build:frontend": "npm --prefix frontend run build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.6",
    "bullmq": "^5.34.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
